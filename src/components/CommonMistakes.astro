---
interface MistakeItem {
  title: string;
  detail: string;
}

interface Props {
  mistakes: (string | MistakeItem)[];
}

const { mistakes } = Astro.props;
---

<div class="common-mistakes" role="region" aria-label="常见错误">
  <h3 id="common-mistakes-title">常见错误</h3>
  <ul aria-labelledby="common-mistakes-title">
    {mistakes.map((mistake) => {
      const title = typeof mistake === "string" ? mistake.split(":")[0] : mistake.title;
      const detail = typeof mistake === "string" ? (mistake.split(":")[1] || mistake) : mistake.detail;
      return (
        <li>
          <details>
            <summary aria-expanded="false">{title}</summary>
            <p>{detail}</p>
          </details>
        </li>
      );
    })}
  </ul>
</div>

<script>
  document
    .querySelectorAll<HTMLDetailsElement>(".common-mistakes details")
    .forEach((details) => {
    const summary = details.querySelector('summary');
    if (!summary) return;
    details.addEventListener('toggle', () => {
      summary.setAttribute('aria-expanded', String(details.open));
    });
  });
</script>

<style>
  .common-mistakes {
    padding: var(--space-md);
    border-left: 4px solid var(--color-error);
    background-color: var(--sl-color-bg-aside);
    border-radius: var(--radius-md);
    margin: var(--space-md) 0;
  }
  .common-mistakes h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: var(--space-sm);
    color: var(--color-error);
  }
  .common-mistakes ul { list-style: none; padding: 0; margin: 0; }
  .common-mistakes li { margin-bottom: var(--space-sm); }
  .common-mistakes details { cursor: pointer; }
  .common-mistakes summary { font-weight: 500; color: var(--sl-color-white); }
  .common-mistakes details[open] summary { margin-bottom: var(--space-sm); }
  .common-mistakes p {
    margin: 0;
    color: var(--sl-color-gray-3);
    font-size: 0.875rem;
  }
</style>
