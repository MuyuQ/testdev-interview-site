---
const { slug, category } = Astro.props;
---

<span class="completion-badge" data-slug={slug} data-category={category} aria-label="完成状态：未完成" role="status">
  <slot />
</span>

<script>
  (function () {
    const badge = document.querySelector('.completion-badge[data-slug]');
    if (!badge) return;

    const slug = badge.getAttribute('data-slug');
    const category = badge.getAttribute('data-category');

    try {
      const data = JSON.parse(localStorage.getItem('testdev:progress') || '{"completed":[]}');
      const isComplete = data.completed.some(
        (e) => e.slug === slug && e.category === category
      );
      if (isComplete) {
        badge.classList.add('completed');
        badge.setAttribute('aria-label', '完成状态：已完成');
      }
    } catch (e) {}
  })();
</script>

<style>
  .completion-badge.completed::after {
    content: "✓";
    color: var(--color-success);
    margin-left: var(--space-xs);
  }
</style>
