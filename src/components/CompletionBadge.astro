---
const { slug, category } = Astro.props;
---

<span
  class="completion-badge"
  data-slug={slug}
  data-category={category}
  aria-label="完成状态：未完成"
  role="status"
>
  <slot />
</span>

<script>
  import { isCompleted } from "../lib/progress-store";

  function initializeCompletionBadges() {
    document
      .querySelectorAll<HTMLElement>(".completion-badge[data-slug]")
      .forEach((badge) => {
        const slug = badge.dataset.slug;
        const category = badge.dataset.category;

        if (!slug || !category) {
          return;
        }

        const completed = isCompleted(slug, category);
        badge.classList.toggle("completed", completed);
        badge.setAttribute(
          "aria-label",
          completed ? "完成状态：已完成" : "完成状态：未完成",
        );
      });
  }

  initializeCompletionBadges();
  document.addEventListener("astro:page-load", initializeCompletionBadges);
</script>

<style>
  .completion-badge.completed::after {
    content: "✓";
    color: var(--color-success);
    margin-left: var(--space-xs);
  }
</style>
