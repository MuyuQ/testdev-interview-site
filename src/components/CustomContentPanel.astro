---
import type { Props } from "@astrojs/starlight/props";
import BookmarkButton from "./BookmarkButton.astro";
import SelfTestQuiz from "./SelfTestQuiz.astro";
import ShareButtons from "./ShareButtons.astro";

const { entry } = Astro.props as Props;
const selfTests = entry.data.selfTests ?? [];
const [category, slug] = entry.slug.split("/");
---

<div class="content-panel" role="main">
  <div class="sl-container">
    <slot />
    <!-- Only render quiz in the content panel (second one), not in the title panel -->
    {selfTests.length > 0 && (
      <div class="quiz-content-only">
        <SelfTestQuiz questions={selfTests} />
      </div>
    )}
    <div class="content-actions" data-content-actions>
      <button
        class="completion-action"
        type="button"
        data-completion-button
        data-category={category}
        data-slug={slug}
        aria-pressed="false"
      >
        标记完成
      </button>
      <BookmarkButton slug={`${category}/${slug}`} />
    </div>
    <div class="share-section">
      <ShareButtons />
    </div>
  </div>
</div>

<style>
  .content-panel {
    padding: 2rem 0;
  }
  .content-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 1px solid var(--sl-color-hairline);
  }
  .completion-action {
    min-height: 2.25rem;
    padding: 0 var(--space-md);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0;
    background: var(--sl-color-bg);
    color: var(--sl-color-gray-1);
    cursor: pointer;
    font: inherit;
    transition:
      border-color var(--transition-fast),
      color var(--transition-fast),
      background-color var(--transition-fast);
  }
  .completion-action:hover {
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent);
    background: var(--sl-color-accent-low);
  }
  .completion-action.completed {
    border-color: var(--color-success);
    color: var(--color-success);
    background: rgba(34, 197, 94, 0.1);
  }
  .share-section {
    margin-top: var(--space-lg);
    padding-top: var(--space-md);
    border-top: 1px solid var(--sl-color-hairline);
  }
  /* 
   * Starlight renders ContentPanel twice for non-hero pages:
   * 1. First panel: contains PageTitle (no .sl-markdown-content)
   * 2. Second panel: contains MarkdownContent (has .sl-markdown-content)
   * 
   * We only want to show the quiz in the second panel (with actual content).
   * Using :has() to detect if this panel contains markdown content.
   */
  .content-panel:not(:has(.sl-markdown-content)) .content-actions,
  .content-panel:not(:has(.sl-markdown-content)) .self-test-quiz,
  .content-panel:not(:has(.sl-markdown-content)) .share-section {
    display: none !important;
  }
</style>

<script>
  import { initializeCompletionControls } from "../lib/progress-store";

  const KEY_PREFIX = "testdev:";
  const MAX_RECENT = 10;

  function trackView() {
    try {
      const path = window.location.pathname;
      const segments = path.split("/").filter(Boolean);
      if (segments.length < 2) return;
      const category = segments[segments.length - 2];
      const slug = segments[segments.length - 1];
      const title = document.querySelector("h1")?.textContent || document.title;
      const recent = JSON.parse(
        localStorage.getItem(KEY_PREFIX + "recent") || "[]",
      ) as Array<{
        slug: string;
        title: string;
        category: string;
        viewedAt: string;
      }>;
      const existing = recent.findIndex((r) => r.slug === slug);
      if (existing >= 0) recent.splice(existing, 1);
      recent.unshift({ slug, title, category, viewedAt: new Date().toISOString() });
      if (recent.length > MAX_RECENT) recent.pop();
      localStorage.setItem(KEY_PREFIX + "recent", JSON.stringify(recent));
    } catch {}
  }

  // Remove duplicate self-test quizzes
  // Starlight renders ContentPanel twice for non-hero pages:
  // 1. First panel: contains PageTitle (no .sl-markdown-content)
  // 2. Second panel: contains MarkdownContent (has .sl-markdown-content)
  // We only want to keep the quiz in the second panel (with actual content).
  function removeDuplicateQuizzes() {
    const quizzes = document.querySelectorAll("[data-quiz]");
    if (quizzes.length <= 1) return;

    // Check if .sl-markdown-content exists (indicates content panel)
    const hasMarkdownContent =
      document.querySelector(".sl-markdown-content") !== null;
    if (!hasMarkdownContent) return;

    // Remove quizzes that are NOT in the content panel
    quizzes.forEach((quiz) => {
      const contentPanel = quiz.closest(".content-panel");
      if (!contentPanel) return;

      // If this content panel doesn't contain .sl-markdown-content, remove the quiz
      if (!contentPanel.querySelector(".sl-markdown-content")) {
        quiz.remove();
      }
    });
  }

  function initializeContentPage() {
    removeDuplicateQuizzes();
    trackView();
    initializeCompletionControls(document);
  }

  // Run on initial load and after page transitions
  initializeContentPage();
  document.addEventListener("astro:page-load", initializeContentPage);
</script>
