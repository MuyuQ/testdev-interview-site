---
import { getCollection } from "astro:content";
import { getHomePageData } from "../lib/home-page";
import RecentViews from "./RecentViews.astro";
import "../styles/home-page.css";

const totalDocsCount = (await getCollection("docs")).length;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const { roadmapLinks, moduleLinks } = getHomePageData(base);
---

<div class="home-page" role="main">
  <section class="hero" aria-label="站点介绍">
    <h1>测试开发面试速成站</h1>
    <p class="hero-subtitle">
      结构化内容帮助你快速补齐测试开发知识框架，在面试中说清楚概念、项目和方案
    </p>
  </section>

  <section class="roadmap-highlights" aria-label="学习路线">
    <h2>学习路线</h2>
    <div class="roadmap-cards">
      {roadmapLinks.map((link) => (
        <a href={link.href} class="roadmap-card">
          <h3>{link.title}</h3>
          <p>{link.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="modules" aria-label="核心模块">
    <h2>核心模块</h2>
    <div class="module-grid">
      {moduleLinks.map((link) => (
        <a href={link.href} class="module-card">
          <h3>{link.title}</h3>
          <p>{link.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section
    class="progress-overview"
    aria-label="学习进度"
    data-total-docs={totalDocsCount}
    hidden
  >
    <h2>学习进度</h2>
    <p data-progress-text>已完成 0 / {totalDocsCount} 个主题</p>
    <div class="progress-bar">
      <div class="progress-bar-fill" data-progress-fill style="width: 0%"></div>
    </div>
  </section>

  <section class="recent-views-section" aria-label="最近浏览" data-base={base}>
    <RecentViews>
      <li id="recent-placeholder" style="color: var(--sl-color-gray-3); font-size: 0.875rem;">暂无浏览记录</li>
    </RecentViews>
  </section>
</div>

<script>
  import { initializeRecentViews } from "../lib/home-page-client";

  function renderProgressOverview() {
    const section =
      document.querySelector<HTMLElement>(".progress-overview");
    if (!section) return;

    const total = Number.parseInt(section.dataset.totalDocs ?? "0", 10);
    const text = section.querySelector<HTMLElement>("[data-progress-text]");
    const fill = section.querySelector<HTMLElement>("[data-progress-fill]");

    try {
      const data = JSON.parse(
        localStorage.getItem("testdev:progress") ?? '{"completed":[]}',
      ) as { completed: unknown[] };
      const completed = Array.isArray(data.completed)
        ? data.completed.length
        : 0;
      const percent = total > 0 ? Math.min((completed / total) * 100, 100) : 0;

      section.hidden = completed <= 0;
      if (text) {
        text.textContent = `已完成 ${completed} / ${total} 个主题`;
      }
      if (fill) {
        fill.style.width = `${percent}%`;
      }
    } catch {
      section.hidden = true;
    }
  }

  function renderRecentViews() {
    const base =
      document
        .querySelector<HTMLElement>(".recent-views-section")
        ?.dataset.base ?? "/";

    initializeRecentViews(base);
  }

  function initializeHomePage() {
    renderProgressOverview();
    renderRecentViews();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeHomePage, {
      once: true,
    });
  } else {
    initializeHomePage();
  }

  document.addEventListener("astro:page-load", initializeHomePage);
</script>
