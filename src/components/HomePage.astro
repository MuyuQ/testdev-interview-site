---
import { getCollection } from "astro:content";
import { getHomePageData, getProgressPercentage } from "../lib/home-page";
import { getProgress } from "../lib/progress-store";
import RecentViews from "./RecentViews.astro";
import "../styles/home-page.css";

const progress = getProgress();
const completedCount = progress.completed.length;
const totalDocsCount = (await getCollection("docs")).length;
const progressPercentage = getProgressPercentage(completedCount, totalDocsCount);
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const { roadmapLinks, moduleLinks } = getHomePageData(base);
---

<div class="home-page" role="main">
  <section class="hero" aria-label="站点介绍">
    <h1>测试开发面试速成站</h1>
    <p class="hero-subtitle">
      结构化内容帮助你快速补齐测试开发知识框架，在面试中说清楚概念、项目和方案
    </p>
  </section>

  <section class="roadmap-highlights" aria-label="学习路线">
    <h2>学习路线</h2>
    <div class="roadmap-cards">
      {roadmapLinks.map((link) => (
        <a href={link.href} class="roadmap-card">
          <h3>{link.title}</h3>
          <p>{link.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="modules" aria-label="核心模块">
    <h2>核心模块</h2>
    <div class="module-grid">
      {moduleLinks.map((link) => (
        <a href={link.href} class="module-card">
          <h3>{link.title}</h3>
          <p>{link.description}</p>
        </a>
      ))}
    </div>
  </section>

  {completedCount > 0 && (
    <section class="progress-overview" aria-label="学习进度">
      <h2>学习进度</h2>
      <p>已完成 {completedCount} / {totalDocsCount} 个主题</p>
      <div class="progress-bar">
        <div class="progress-bar-fill" style={`width: ${progressPercentage}%`}></div>
      </div>
    </section>
  )}

  <section class="recent-views-section" aria-label="最近浏览" data-base={base}>
    <RecentViews>
      <li id="recent-placeholder" style="color: var(--sl-color-gray-3); font-size: 0.875rem;">暂无浏览记录</li>
    </RecentViews>
  </section>
</div>

<script>
  import { initializeRecentViews } from "../lib/home-page-client";

  function renderRecentViews() {
    const base =
      document
        .querySelector<HTMLElement>(".recent-views-section")
        ?.dataset.base ?? "/";

    initializeRecentViews(base);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", renderRecentViews, {
      once: true,
    });
  } else {
    renderRecentViews();
  }
</script>
