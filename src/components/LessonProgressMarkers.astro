---
const completedSlugs = Astro.props.completedSlugs || [];
const completedJson = JSON.stringify(completedSlugs);
---

<script data-completed={completedJson}>
  (function () {
    const script = document.currentScript;
    if (!script) return;

    const completed = new Set(
      JSON.parse(script.getAttribute("data-completed") || "[]")
    );

    document.querySelectorAll("[data-slug]").forEach((el) => {
      const slug = el.getAttribute("data-slug");
      if (slug && completed.has(slug)) {
        el.classList.add("completed");
      }
    });
  })();
</script>

<style>
  .completed::after {
    content: "✓";
    color: var(--color-success);
    margin-left: var(--space-sm);
  }
</style>
