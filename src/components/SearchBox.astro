---
// SearchBox.astro - 搜索按钮组件，触发 Starlight Pagefind 搜索模态框
---
<button
  class="search-btn"
  aria-label="搜索"
  id="search-trigger"
  type="button"
>
  <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="11" cy="11" r="8"/>
    <path d="m21 21-4.35-4.35"/>
  </svg>
  <span class="search-shortcut">Ctrl+K</span>
</button>

<script>
  function openSearch() {
    // 方法1: 尝试触发 Starlight 内置搜索事件
    const searchEvent = new KeyboardEvent('keydown', {
      key: 'k',
      code: 'KeyK',
      ctrlKey: true,
      metaKey: true,
      bubbles: true
    });
    document.dispatchEvent(searchEvent);

    // 方法2: 如果 Starlight 搜索按钮存在，直接点击
    const searchButton = document.querySelector(
      'button[aria-label="搜索"], button[aria-label="Search"], .sl-search-btn, [data-starlight-search]'
    );
    if (searchButton) {
      searchButton.click();
    }
  }

  const trigger = document.getElementById('search-trigger');
  trigger?.addEventListener('click', openSearch);

  // 全局键盘快捷键监听
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
    }
  });
</script>

<style>
  .search-btn {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    background: var(--sl-color-bg-card);
    border: 1px solid var(--sl-color-hairline);
    border-radius: var(--radius-md);
    cursor: pointer;
    padding: var(--space-xs) var(--space-sm);
    color: var(--sl-color-gray-3);
    font-size: 0.75rem;
    transition: all var(--transition-fast);
    min-width: 120px;
  }

  .search-btn:hover {
    color: var(--sl-color-accent);
    border-color: var(--sl-color-accent);
    background: var(--sl-color-accent-low);
  }

  .search-btn:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  .search-icon {
    flex-shrink: 0;
  }

  .search-shortcut {
    opacity: 0.6;
    font-family: var(--font-mono);
    font-size: 0.65rem;
  }

  @media (max-width: 768px) {
    .search-btn {
      min-width: auto;
      padding: var(--space-sm);
    }

    .search-shortcut {
      display: none;
    }
  }
</style>
