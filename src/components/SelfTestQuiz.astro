---
interface SelfTestQuestion {
  id: string;
  question: string;
  options: string[];
  correctIndex: number;
  explanation: string;
}

interface Props {
  questions: SelfTestQuestion[];
}

const { questions } = Astro.props;
if (!questions?.length) return null;
---

<div class="self-test-quiz" data-quiz>
  <h2>自测题</h2>
  <p class="quiz-intro">完成以下 {questions.length} 道题目，检验你的学习成果</p>

  {questions.map((q, i) => (
    <div class="quiz-question" data-question-id={q.id}>
      <h3>问题 {i + 1}</h3>
      <p class="quiz-question-text">{q.question}</p>
      <div class="quiz-options">
        {q.options.map((opt, j) => (
          <label class="quiz-option">
            <input type="radio" name={`q-${q.id}`} value={j} />
            <span class="option-text">{opt}</span>
          </label>
        ))}
      </div>
      <div class="quiz-actions">
        <button class="quiz-check-btn" data-correct={q.correctIndex} data-question={q.id}>检查答案</button>
      </div>
      <div class="quiz-explanation" data-explanation={q.id} hidden>
        <p><strong>解析：</strong>{q.explanation}</p>
      </div>
    </div>
  ))}

  <div class="quiz-summary" hidden>
    <h3>测验结果</h3>
    <p class="quiz-score"></p>
    <button class="quiz-reset-btn">重新测验</button>
  </div>
</div>

<script>
  (function () {
    const quiz = document.querySelector('[data-quiz]');
    if (!quiz) return;

    const questions = quiz.querySelectorAll('.quiz-question');
    const summary = quiz.querySelector('.quiz-summary');
    const scoreEl = quiz.querySelector('.quiz-score');
    let answered = 0;
    let correct = 0;

    quiz.querySelectorAll('.quiz-check-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const question = btn.closest('.quiz-question');
        const correctIndex = parseInt(btn.dataset.correct);
        const selected = question.querySelector('input:checked');
        const explanation = question.querySelector('[data-explanation]');

        if (!selected) {
          alert('请选择一个答案');
          return;
        }

        const selectedIndex = parseInt(selected.value);
        const options = question.querySelectorAll('.quiz-option');

        options.forEach((opt, i) => {
          opt.classList.toggle('correct', i === correctIndex);
          opt.classList.toggle('wrong', i === selectedIndex && i !== correctIndex);
          opt.querySelector('input').disabled = true;
        });

        if (selectedIndex === correctIndex) {
          correct++;
        }
        answered++;

        explanation.hidden = false;
        btn.disabled = true;
        btn.textContent = '已检查';

        if (answered === questions.length) {
          showSummary();
        }
      });
    });

    function showSummary() {
      const total = questions.length;
      const percent = Math.round((correct / total) * 100);
      scoreEl.textContent = `答对 ${correct}/${total} 题 (${percent}%)`;
      summary.hidden = false;
      summary.scrollIntoView({ behavior: 'smooth' });
    }

    quiz.querySelector('.quiz-reset-btn')?.addEventListener('click', () => {
      answered = 0;
      correct = 0;
      summary.hidden = true;

      quiz.querySelectorAll('.quiz-question').forEach((q) => {
        q.querySelectorAll('input').forEach((input) => {
          input.checked = false;
          input.disabled = false;
        });
        q.querySelectorAll('.quiz-option').forEach((opt) => {
          opt.classList.remove('correct', 'wrong');
        });
        q.querySelector('.quiz-check-btn').disabled = false;
        q.querySelector('.quiz-check-btn').textContent = '检查答案';
        q.querySelector('[data-explanation]').hidden = true;
      });
    });
  })();
</script>

<style>
  .self-test-quiz {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--sl-color-hairline);
  }

  .self-test-quiz h2 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .quiz-intro {
    color: var(--sl-color-gray-3);
    margin-bottom: 2rem;
  }

  .quiz-question {
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: var(--sl-color-bg-aside);
    border-radius: var(--radius-md);
    border: 1px solid var(--sl-color-hairline);
  }

  .quiz-question h3 {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--sl-color-gray-3);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .quiz-question-text {
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 1rem;
    color: var(--sl-color-white);
  }

  .quiz-options {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .quiz-option {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: background var(--transition-fast);
    border: 1px solid transparent;
  }

  .quiz-option:hover {
    background: var(--sl-color-gray-6);
  }

  .quiz-option input[type="radio"] {
    margin: 0;
    accent-color: var(--sl-color-accent);
  }

  .quiz-option.correct {
    background: rgba(34, 197, 94, 0.15);
    border-color: #22c55e;
  }

  .quiz-option.wrong {
    background: rgba(239, 68, 68, 0.15);
    border-color: #ef4444;
  }

  .quiz-actions {
    margin-top: 1rem;
  }

  .quiz-check-btn {
    padding: 0.5rem 1.25rem;
    background: var(--sl-color-accent);
    color: #ffffff;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all var(--transition-fast);
  }

  .quiz-check-btn:hover:not(:disabled) {
    opacity: 0.9;
  }

  .quiz-check-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .quiz-explanation {
    margin-top: 1rem;
    padding: 1rem;
    background: var(--sl-color-accent-low);
    border-radius: var(--radius-sm);
    border-left: 4px solid var(--sl-color-accent);
  }

  .quiz-explanation p {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--sl-color-gray-1);
  }

  .quiz-summary {
    margin-top: 2rem;
    padding: 1.5rem;
    background: var(--sl-color-bg-aside);
    border-radius: var(--radius-md);
    border: 1px solid var(--sl-color-hairline);
    text-align: center;
  }

  .quiz-summary h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .quiz-score {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--sl-color-accent);
    margin-bottom: 1rem;
  }

  .quiz-reset-btn {
    padding: 0.5rem 1.25rem;
    background: transparent;
    color: var(--sl-color-accent);
    border: 1px solid var(--sl-color-accent);
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-size: 0.875rem;
    transition: all var(--transition-fast);
  }

  .quiz-reset-btn:hover {
    background: var(--sl-color-accent);
    color: #ffffff;
  }

  [data-theme="dark"] .quiz-option:hover {
    background: rgba(224, 226, 230, 0.07);
  }

  [data-theme="dark"] .quiz-option.correct {
    background: rgba(34, 197, 94, 0.15);
  }

  [data-theme="dark"] .quiz-option.wrong {
    background: rgba(239, 68, 68, 0.15);
  }
</style>
