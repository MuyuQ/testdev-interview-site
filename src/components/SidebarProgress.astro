<script is:inline>
  (function () {
    const entries = document.querySelectorAll(
      ".starlight-sidebar a[aria-current='page']",
    );
    entries.forEach((entry) => {
      entry.classList.add("current-page");
    });
  })();
</script>

<style>
  .current-page {
    font-weight: 600;
    color: var(--sl-color-accent);
  }
</style>
