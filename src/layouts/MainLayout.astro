---
import JsonLd from "../components/JsonLd.astro";
/** @type {any} */
import ThemeProvider from "@astrojs/starlight/components/ThemeProvider.astro";

interface Props {
  title: string;
  description?: string;
  type?: "website" | "article";
  datePublished?: string;
  dateModified?: string;
  breadcrumbs?: Array<{ name: string; url: string }>;
}

const {
  title,
  description = "结构化内容帮助你快速补齐测试开发知识框架",
  type = "website",
  datePublished,
  dateModified,
  breadcrumbs,
} = Astro.props;

const canonicalUrl = Astro.url.href;
const ogImageUrl = "https://muyuq.github.io/testdev-interview-site/og-image.png";
---

<!doctype html>
<html lang="zh-CN" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    {/* Canonical URL */}
    <link rel="canonical" href={canonicalUrl} />

    {/* Open Graph */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:site_name" content="测试开发面试速成站" />
    <meta property="og:type" content={type === "article" ? "article" : "website"} />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {/* Robots */}
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    <title>{title}</title>
    {/* @ts-ignore */}
    <ThemeProvider />
  </head>
  <body>
    <slot />
    <JsonLd
      type={type}
      title={title}
      description={description}
      datePublished={datePublished}
      dateModified={dateModified}
      breadcrumbs={breadcrumbs}
    />
  </body>
</html>
