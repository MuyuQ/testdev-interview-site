---
import Layout from "../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

const allDocs = await getCollection("docs");
const beginnerDocs = allDocs.filter((doc) => doc.data.difficulty === "beginner");
const interviewDocs = allDocs.filter((doc) => doc.data.difficulty === "interview");
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<Layout title="难度索引 - 测试开发面试速成站">
  <div class="difficulty-page">
    <h1>难度索引</h1>
    <p>共 {allDocs.length} 篇内容，入门级 {beginnerDocs.length} 篇，面试级 {interviewDocs.length} 篇</p>
    <div class="difficulty-sections">
      <section>
        <h2>入门级 <span class="count">({beginnerDocs.length})</span></h2>
        <p>适合测试开发初学者的基础知识</p>
        <ul class="topic-list">
          {beginnerDocs.map((doc) => (
            <li>
              <a href={`${base}${doc.slug}/`}>{doc.data.title}</a>
              <span class="topic-category">[{doc.data.category}]</span>
            </li>
          ))}
        </ul>
      </section>
      <section>
        <h2>面试级 <span class="count">({interviewDocs.length})</span></h2>
        <p>面试高频问题和技术专题</p>
        <ul class="topic-list">
          {interviewDocs.map((doc) => (
            <li>
              <a href={`${base}${doc.slug}/`}>{doc.data.title}</a>
              <span class="topic-category">[{doc.data.category}]</span>
            </li>
          ))}
        </ul>
      </section>
    </div>
  </div>
</Layout>

<style>
  .difficulty-page { max-width: 800px; margin: 0 auto; padding: 2rem 1rem; }
  .difficulty-page h1 { font-size: 2rem; margin-bottom: 0.5rem; }
  .difficulty-page > p { color: var(--sl-color-gray-3); margin-bottom: 2rem; }
  .difficulty-sections { display: grid; gap: 2rem; }
  .difficulty-sections section { padding: 1.5rem; border: 1px solid var(--sl-color-hairline); border-radius: var(--radius-md); }
  .difficulty-sections h2 { font-size: 1.25rem; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem; }
  .count { font-size: 0.875rem; color: var(--sl-color-gray-3); font-weight: 400; }
  .topic-list { list-style: none; padding: 0; margin: 1rem 0 0; }
  .topic-list li { padding: 0.25rem 0; display: flex; align-items: center; gap: 0.5rem; }
  .topic-list a { color: var(--sl-color-white); text-decoration: none; }
  .topic-list a:hover { text-decoration: underline; color: var(--sl-color-accent); }
  .topic-category { font-size: 0.75rem; color: var(--sl-color-gray-3); }
</style>
