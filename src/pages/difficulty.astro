---
import Layout from "../layouts/MainLayout.astro";
---

<Layout title="难度索引 - 测试开发面试速成站">
  <div class="difficulty-page">
    <h1>难度索引</h1>
    <div class="difficulty-sections">
      <section>
        <h2>入门级</h2>
        <p>适合测试开发初学者的基础知识</p>
        <div id="beginner-topics"></div>
      </section>
      <section>
        <h2>面试级</h2>
        <p>面试高频问题和技术专题</p>
        <div id="interview-topics"></div>
      </section>
    </div>
  </div>
</Layout>

<style>
  .difficulty-page { max-width: 800px; margin: 0 auto; padding: 2rem 1rem; }
  .difficulty-sections { display: grid; gap: 2rem; margin-top: 1.5rem; }
  .difficulty-sections section { padding: 1rem; border: 1px solid var(--sl-color-hairline); border-radius: 0.5rem; }
  .difficulty-sections h2 { font-size: 1.25rem; margin-bottom: 0.5rem; }
</style>
